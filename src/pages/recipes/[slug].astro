---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getAllRecipes, getRecipePhases, renderRecipeBody } from '../../lib/recipes';

const heroModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/recipes/*.png',
  { eager: true },
);
const heroBySlug: Record<string, ImageMetadata> = {};
for (const [filePath, module] of Object.entries(heroModules)) {
  const filename = filePath.split('/').pop()?.replace(/\.png$/, '');
  if (filename && !filename.startsWith('_')) {
    heroBySlug[filename] = module.default;
  }
}

export function getStaticPaths() {
  return getAllRecipes().map((recipe) => ({
    params: { slug: recipe.slug },
    props: {
      html: renderRecipeBody(recipe.body),
      phaseLinks: getRecipePhases(recipe.body),
      recipe,
    },
  }));
}

const { html, phaseLinks, recipe } = Astro.props;
const heroImage = heroBySlug[recipe.slug];
---

<SiteLayout title={`${recipe.title} | Modernist Recipe Book`} description={recipe.excerpt}>
  <section class="page-header page-header--tight">
    <a class="back-link" href="/recipes/">All recipes</a>
    <p class="eyebrow">{recipe.dateLabel}</p>
    <h1>{recipe.title}</h1>
    <div class="fact-strip" aria-label="Recipe facts">
      {recipe.dishType && <span>{recipe.dishType}</span>}
      <span>{recipe.phaseCount} phases</span>
      {recipe.yieldText && <span>{recipe.yieldText}</span>}
      {recipe.serviceTarget && <span>Service {recipe.serviceTarget}</span>}
      {recipe.primaryIngredient && <span>{recipe.primaryIngredient}</span>}
    </div>
  </section>

  {
    heroImage && (
      <figure class="recipe-hero">
        <Picture
          class="recipe-hero__image"
          src={heroImage}
          alt={`Specimen photograph for ${recipe.title}`}
          widths={[800, 1200, 1600]}
          sizes="(min-width: 900px) 900px, 100vw"
          formats={['avif', 'webp']}
          loading="eager"
          decoding="async"
        />
      </figure>
    )
  }

  <article class="recipe-sheet">
    <div class="recipe-workbench">
      {
        phaseLinks.length > 0 && (
          <aside class="phase-nav" aria-label="Recipe phases">
            <p class="phase-nav__label">Run sheet</p>
            <ol>
              {phaseLinks.map((phase) => (
                <li>
                  <a href={`#${phase.id}`}>{phase.title.replace(/^PHASE\s+/u, '')}</a>
                </li>
              ))}
            </ol>
          </aside>
        )
      }
      <div class="recipe-body" set:html={html} />
    </div>
  </article>
</SiteLayout>

---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { RecipeEntry } from '../lib/recipes';

interface Props {
  recipe: RecipeEntry;
}

const heroModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/recipes/*.png',
  { eager: true },
);
const heroBySlug: Record<string, ImageMetadata> = {};
for (const [filePath, module] of Object.entries(heroModules)) {
  const filename = filePath.split('/').pop()?.replace(/\.png$/, '');
  if (filename && !filename.startsWith('_')) {
    heroBySlug[filename] = module.default;
  }
}

const { recipe } = Astro.props;
const taxonomyTags = recipe.tags.filter((tag) => !tag.startsWith('dish-'));
const visibleTags = taxonomyTags.slice(0, 3);
const heroImage = heroBySlug[recipe.slug];
const searchIndex = [
  recipe.title,
  recipe.excerpt,
  recipe.dishType,
  recipe.yieldText,
  recipe.serviceTarget,
  recipe.primaryIngredient,
  ...recipe.tags,
]
  .filter(Boolean)
  .join(' ')
  .toLowerCase();
---

<article
  class="recipe-card"
  data-recipe-card
  data-dish={recipe.dishType ?? ''}
  data-search={searchIndex}
  data-tags={taxonomyTags.join(' ')}
>
  {
    heroImage && (
      <a class="recipe-card__thumb" href={recipe.href} tabindex="-1" aria-hidden="true">
        <Picture
          src={heroImage}
          alt=""
          widths={[400, 600, 800]}
          sizes="(min-width: 900px) 380px, 100vw"
          formats={['avif', 'webp']}
          loading="lazy"
          decoding="async"
        />
      </a>
    )
  }
  <p class="recipe-card__date">{recipe.dateLabel}</p>
  <h3 class="recipe-card__title">
    <a href={recipe.href}>{recipe.title}</a>
  </h3>
  <p class="recipe-card__excerpt">{recipe.excerpt}</p>
  <div class="recipe-card__facts">
    {recipe.dishType && <span>{recipe.dishType}</span>}
    <span>{recipe.phaseCount} phases</span>
    {recipe.yieldText && <span>{recipe.yieldText}</span>}
    {recipe.serviceTarget && <span>Service {recipe.serviceTarget}</span>}
  </div>
  {
    visibleTags.length > 0 && (
      <ul class="tag-list">
        {visibleTags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )
  }
</article>

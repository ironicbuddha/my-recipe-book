---
import type { RecipeEntry } from '../lib/recipes';

interface Props {
  recipe: RecipeEntry;
}

const { recipe } = Astro.props;
const taxonomyTags = recipe.tags.filter((tag) => !tag.startsWith('dish-'));
const visibleTags = taxonomyTags.slice(0, 3);
const searchIndex = [
  recipe.title,
  recipe.excerpt,
  recipe.dishType,
  recipe.yieldText,
  recipe.serviceTarget,
  recipe.primaryIngredient,
  ...recipe.tags,
]
  .filter(Boolean)
  .join(' ')
  .toLowerCase();
---

<article
  class="recipe-card"
  data-recipe-card
  data-dish={recipe.dishType ?? ''}
  data-search={searchIndex}
  data-tags={taxonomyTags.join(' ')}
>
  <p class="recipe-card__date">{recipe.dateLabel}</p>
  <h3 class="recipe-card__title">
    <a href={recipe.href}>{recipe.title}</a>
  </h3>
  <p class="recipe-card__excerpt">{recipe.excerpt}</p>
  <div class="recipe-card__facts">
    {recipe.dishType && <span>{recipe.dishType}</span>}
    <span>{recipe.phaseCount} phases</span>
    {recipe.yieldText && <span>{recipe.yieldText}</span>}
    {recipe.serviceTarget && <span>Service {recipe.serviceTarget}</span>}
  </div>
  {
    visibleTags.length > 0 && (
      <ul class="tag-list">
        {visibleTags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )
  }
</article>
